# ==============================================
# BANCO DE DADOS
# ==============================================
POSTGRES_DB=financeiro_encontro
POSTGRES_USER=financeiro
POSTGRES_PASSWORD=sua_senha_aqui

# Use @postgres para Docker, @localhost para desenvolvimento local
DATABASE_URL=postgresql://financeiro:sua_senha_aqui@postgres:5432/financeiro_encontro

# ==============================================
# BACKEND
# ==============================================
UPLOAD_FOLDER=./uploads
APP_PORT=8000

# ==============================================
# JWT
# ==============================================
# Gere um valor seguro com:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=sua_chave_secreta_aqui
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ==============================================
# CORS / FRONTEND
# ==============================================
# Origens permitidas para o backend (separadas por vírgula)
# Em Docker (Opção 1): http://localhost
# Em desenvolvimento local (Opção 2): http://localhost:4200
CORS_ORIGINS=http://localhost

# URL do backend usada no build do frontend (compilada no bundle Angular)
# Em Docker (Opção 1): http://localhost:8000
# Em produção na nuvem: https://api.seudominio.com
API_URL=http://localhost:8000

# ==============================================
# PGADMIN (docker-compose-db.yml)
# ==============================================
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin
